export function safeEstimateTokens(text: string): number {
	try {
		return estimateTokens(text);
	} catch {
		logger.debug(
			undefined,
			"tokens.estimate",
			"Token estimation failed, using fallback",
		);
		return Math.ceil(text.length * 0.25); // Fallback estimation
	}
}

