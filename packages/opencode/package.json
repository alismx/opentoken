{
	"name": "@mrgray17/opentoken",
	"version": "2.1.0",
	"description": "OpenCode plugin for OpenToken — token-saving companion",
	"type": "module",
	"license": "MIT",
	"main": "./dist/plugin.js",
	"engines": {
		"bun": ">=1.2.0"
	},
	"homepage": "https://github.com/MrGray17/opentoken",
	"bugs": {
		"url": "https://github.com/MrGray17/opentoken/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/MrGray17/opentoken.git",
		"directory": "packages/opencode"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/plugin.js",
			"default": "./dist/plugin.js"
		},
		"./tui": {
			"import": "./dist/tui.js",
			"default": "./dist/tui.js"
		}
	},
	"scripts": {
		"build": "bun build --target=node --outdir=dist --external @opencode-ai/plugin src/plugin.ts && bun build --target=node --outdir=dist --external solid-js --external @opentui/solid --external @opentui/core src/tui.tsx",
		"prepack": "bun run build"
	},
	"dependencies": {
		"@opencode-ai/plugin": "^1.15.5",
		"@opentui/solid": "^0.2.14",
		"@opentui/core": "^0.2.14",
		"solid-js": "1.9.12"
	},
	"devDependencies": {
		"@mrgray17/opentoken-core": "^2.1.0",
		"@types/bun": "^1.3.14",
		"typescript": "^5.9.3"
	}
}
