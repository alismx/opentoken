{
	"name": "@mrgray17/opentoken",
	"version": "2.0.0",
	"description": "OpenCode plugin for OpenToken — token-saving companion",
	"type": "module",
	"license": "MIT",
	"engines": {
		"bun": ">=1.2.0"
	},
	"homepage": "https://github.com/MrGray17/opentoken",
	"bugs": {
		"url": "https://github.com/MrGray17/opentoken/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/MrGray17/opentoken.git",
		"directory": "packages/opencode"
	},
	"files": [
		"src/**/*.ts",
		"src/**/*.tsx"
	],
	"exports": {
		".": {
			"import": "./src/plugin.ts",
			"default": "./src/plugin.ts"
		},
		"./tui": {
			"import": "./src/tui.tsx",
			"default": "./src/tui.tsx"
		}
	},
	"dependencies": {
		"@opentoken/core": "workspace:*",
		"@opencode-ai/plugin": "^1.15.5",
		"@opentui/solid": "^0.2.14",
		"@opentui/core": "^0.2.14",
		"solid-js": "1.9.12"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"typescript": "^5.9.3"
	}
}
