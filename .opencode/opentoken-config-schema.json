{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/MrGray17/opentoken/raw/main/.opencode/opentoken-config-schema.json",
  "title": "OpenToken Config",
  "description": "Configuration schema for ~/.config/opentoken/config.json",
  "type": "object",
  "properties": {
    "maxOutputBytes": {
      "type": "integer",
      "minimum": 1048576,
      "maximum": 104857600,
      "default": 10485760,
      "description": "Hard limit — reject outputs larger than this (1MB–100MB)"
    },
    "maxProcessingMs": {
      "type": "integer",
      "minimum": 100,
      "maximum": 30000,
      "default": 5000,
      "description": "Timeout per pipeline stage in ms"
    },
    "safeReadRoot": {
      "type": "string",
      "pattern": "^(|[a-zA-Z0-9_/.-]+)$",
      "default": "",
      "description": "Only allow reads under this directory (empty = use project directory)"
    },
    "enableMetrics": {
      "type": "boolean",
      "default": true,
      "description": "Track token savings to disk"
    },
    "enableSymbolIndex": {
      "type": "boolean",
      "default": true,
      "description": "Build and query symbol index at startup"
    },
    "conservativeUseTokens": {
      "type": "boolean",
      "default": false,
      "description": "Use token count (slower) vs byte count (faster) for safety check"
    },
    "enableHistoryCompression": {
      "type": "boolean",
      "default": false,
      "description": "Kill switch for experimental hooks"
    },
    "historyCompressionWindow": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 12,
      "description": "Messages to keep full-fidelity"
    },
    "enableSessionMemory": {
      "type": "boolean",
      "default": false,
      "description": "Cross-session memory persistence"
    },
    "enableTui": {
      "type": "boolean",
      "default": true,
      "description": "TUI status bar"
    },
    "tuiUseEmoji": {
      "type": "boolean",
      "default": true,
      "description": "TUI: use emoji vs ASCII fallback"
    },
    "allowLockFileReads": {
      "type": "boolean",
      "default": false,
      "description": "Allow reading lock files despite minified/generated blocking"
    },
    "enableOutputSaving": {
      "type": "boolean",
      "default": true,
      "description": "Reduce output tokens via system directives, budget caps, and response compression"
    }
  },
  "additionalProperties": false
}
