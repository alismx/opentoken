		s.level = "off";
		s.history.push({
			level: "off",
			fillPct: s.fillPct,
			timestamp: Date.now(),
		});
	} else if (s.fillPct < 0.8 && s.level === "ceiling") {
		s.level = "ultra";
		s.history.push({
			level: "ultra",
			fillPct: s.fillPct,
			timestamp: Date.now(),
		});
	} else if (s.fillPct < 0.7 && s.level === "ultra") {
		s.level = "lean";
		s.history.push({
			level: "lean",
			fillPct: s.fillPct,
			timestamp: Date.now(),
		});
	}
	return s.level;
}
