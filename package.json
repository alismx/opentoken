{
  "name": "@mrgray17/opentoken",
  "version": "1.2.0",
  "description": "Token-saving companion for OpenCode — intercepts, filters, and compresses tool outputs before they reach the model",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/MrGray17/opentoken",
  "bugs": {
    "url": "https://github.com/MrGray17/opentoken/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrGray17/opentoken.git"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "token-savings",
    "llm",
    "compression"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tui": {
      "import": "./src/tui.tsx",
      "default": "./src/tui.tsx"
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "checks:regex": "bun run scripts/check-regex-safety.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.5",
    "@opentui/solid": "^0.2.14",
    "@opentui/core": "^0.2.14",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
